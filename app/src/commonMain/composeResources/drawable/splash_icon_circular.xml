<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. Background Circle (Matching Compose size) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#1a1a2e" />
            <size android:width="120dp" android:height="120dp" />
        </shape>
    </item>

    <!-- 2. The Static Loading Ring (To make it appear instantly) -->
    <!-- Gradient ring around the circle -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="4dp" android:color="#4D00d9ff" />
            <size android:width="160dp" android:height="160dp" />
        </shape>
    </item>

    <!-- 3. The Blitz Math Logo (Centered, matching 12dp padding in 120dp box) -->
    <item
        android:drawable="@mipmap/ic_launcher_foreground"
        android:gravity="center"
        android:top="12dp"
        android:bottom="12dp"
        android:left="12dp"
        android:right="12dp" />
</layer-list>
